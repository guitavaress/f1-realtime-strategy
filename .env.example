# Copiar para .env e ajustar para o ambiente local
# NUNCA commitar o .env real

DATABASE_URL=postgresql://airflow:airflow@localhost:5432/f1
REDIS_URL=redis://localhost:6379/0

# Cache do FastF1 (opcional — padrão: ./cache)
FASTF1_CACHE_DIR=./cache

# Open-Meteo não requer key; deixar vazio para usar endpoint padrão
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast

# undercut-f1 sidecar (Fase 2) — ajustar se rodar fora do Docker
# Em Docker: http://undercut:5000  |  Local sem Docker: http://localhost:5000
UNDERCUT_URL=http://localhost:5000
